#usda 1.0
(
    defaultPrim = "MarketLab"
)

def Scope "MarketLab"
{
    def FinancialAsset "SPY"
    {
        bool inputs:active = 1
        token inputs:symbol = "SPY"
        token inputs:asset_class = "Equity"
        token inputs:provider = "yahoo"
        custom float risk_budget = 1.0
    }
}
