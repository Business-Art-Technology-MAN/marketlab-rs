// TLT leg weight — defense mode: max bivector among oriented havens.

float wedge,
float panic_thresh,
float defense_thresh,
float tlt_orient,
float gld_orient,
float tlt_bivector,
float gld_bivector,
output float tlt_w
{
    tlt_w = ga::month_end()
        * step(defense_thresh - wedge, 1.0)
        * step(wedge - panic_thresh, 1.0)
        * (
            tlt_orient * step(0.0 - gld_orient, 1.0)
            + tlt_orient * gld_orient * step(gld_bivector - tlt_bivector, 1.0)
        );
}
